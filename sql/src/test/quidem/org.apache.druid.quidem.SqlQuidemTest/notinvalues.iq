# Verify that inSubQueryThreshold is respected: lowering it to 0 forces the rule to be skipped.
# Need !set + !use to reconnect so the property takes effect.
!set inSubQueryThreshold 0
!use druidtest:///
!set outputformat mysql
SELECT cnt
FROM foo
WHERE cnt NOT IN (SELECT col FROM (VALUES(0), (999)) AS t(col));
+-----+
| cnt |
+-----+
|   1 |
|   1 |
|   1 |
|   1 |
|   1 |
|   1 |
+-----+
(6 rows)

