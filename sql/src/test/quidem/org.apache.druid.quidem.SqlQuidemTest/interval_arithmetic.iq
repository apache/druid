    "name" : "foo"
  },
  "intervals" : {
    "type" : "intervals",
    "intervals" : [ "1999-12-30T00:00:00.000Z/2000-01-03T00:00:00.000Z" ]
  },
  "resultFormat" : "compactedList",
  "order" : "ascending",
  "columns" : [ "__time" ],
  "columnTypes" : [ "LONG" ],
  "granularity" : {
    "type" : "all"
  },
  "legacy" : false
}
!nativePlan

