!use druidtest:///
!set outputformat mysql

# Case 1: BIGINT (foo2.m1) vs FLOAT (foo.m1).
SELECT dim1, dim2, SUM(m1), COUNT(*)
FROM (SELECT dim1, dim2, m1 FROM foo2 UNION ALL SELECT dim1, dim2, m1 FROM foo)
WHERE dim2 = 'a' OR dim2 = 'en'
GROUP BY 1, 2;
+-------+------+--------+--------+
| dim1  | dim2 | EXPR$2 | EXPR$3 |
+-------+------+--------+--------+
|       | a    |    1.0 |      1 |
| 1     | a    |    4.0 |      1 |
| druid | en   |    1.0 |      1 |
+-------+------+--------+--------+
(3 rows)

!ok
{
  "queryType" : "groupBy",
  "dataSource" : {
    "type" : "union",
    "dataSources" : [ {
      "type" : "table",
      "name" : "foo2"
    }, {
      "type" : "table",
      "name" : "foo"
    } ]
  },
  "intervals" : {
    "type" : "intervals",
    "intervals" : [ "-146136543-09-08T08:23:32.096Z/146140482-04-24T15:36:27.903Z" ]
  },
  "filter" : {
    "type" : "inType",
    "column" : "dim2",
    "matchValueType" : "STRING",
    "sortedValues" : [ "a", "en" ]
  },
  "granularity" : {
    "type" : "all"
  },
  "dimensions" : [ {
    "type" : "default",
    "dimension" : "dim1",
    "outputName" : "d0",
    "outputType" : "STRING"
  }, {
    "type" : "default",
    "dimension" : "dim2",
    "outputName" : "d1",
    "outputType" : "STRING"
  } ],
  "aggregations" : [ {
    "type" : "doubleSum",
    "name" : "a0",
    "fieldName" : "m1"
  }, {
    "type" : "count",
    "name" : "a1"
  } ],
  "limitSpec" : {
    "type" : "NoopLimitSpec"
  }
}
!nativePlan

# Case 2: Same numeric types. foo.m1 FLOAT and numfoo.m1 FLOAT.
SELECT dim1, SUM(m1), COUNT(*)
FROM (SELECT dim1, m1 FROM foo UNION ALL SELECT dim1, m1 FROM numfoo)
WHERE dim1 = 'a' OR dim1 = '1'
GROUP BY 1;
