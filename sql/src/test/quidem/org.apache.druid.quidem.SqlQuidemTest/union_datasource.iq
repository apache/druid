# Case 5: Filter in one arm. Not a bare TableScan, DruidUnionDataSourceRule cannot match.
SELECT dim1, SUM(m1), COUNT(*)
FROM (SELECT dim1, m1 FROM foo2 WHERE dim1 = '1' UNION ALL SELECT dim1, m1 FROM foo)
GROUP BY 1;
SQL requires union between inputs that are not simple table scans and involve a filter or aliasing
!error

# Case 6: Column aliasing. Names differ between arms (mapping required).
SELECT c, COUNT(*)
FROM (SELECT dim1 AS c, m1 FROM foo UNION ALL SELECT dim2 AS c, m1 FROM foo2)
WHERE c = 'a' OR c = '1'
GROUP BY 1;
SQL requires union between two tables and column names queried for each table are different
!error

# Case 7: Outer WHERE only, no GROUP BY.
SELECT dim1, m1
FROM (SELECT dim1, m1 FROM foo2 UNION ALL SELECT dim1, m1 FROM foo)
WHERE dim1 = 'a' OR dim1 = '1';
+------+-----+
| dim1 | m1  |
+------+-----+
| 1    | 4.0 |
+------+-----+
(1 row)

!ok
