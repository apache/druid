# Case 9: Multiple mismatching columns at once (m1 + dim3).
SELECT dim1, SUM(m1), MAX(dim3), COUNT(*)
FROM (SELECT dim1, m1, dim3 FROM foo UNION ALL SELECT dim1, m1, dim3 FROM foo2)
GROUP BY 1;
SQL requires union between inputs that are not simple table scans and involve a filter or aliasing
!error

# Case 10: SELECT * union. full row, m1 FLOAT vs BIGINT, dim3 STRING vs LONG.
SELECT dim2, SUM(m1), COUNT(*)
FROM (SELECT * FROM foo UNION ALL SELECT * FROM foo2)
WHERE dim2 = 'a' OR dim2 = 'en'
GROUP BY 1;
+------+--------+--------+
| dim2 | EXPR$1 | EXPR$2 |
+------+--------+--------+
| a    |    5.0 |      2 |
| en   |    1.0 |      1 |
+------+--------+--------+
(2 rows)

!ok
