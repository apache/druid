FROM (SELECT dim1, m1 FROM foo UNION ALL SELECT dim1, m1 FROM foo2 UNION ALL SELECT dim1, m1 FROM numfoo)
WHERE dim1 = 'a' OR dim1 = '1'
GROUP BY 1;
