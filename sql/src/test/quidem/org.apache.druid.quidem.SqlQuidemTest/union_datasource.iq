# Case 8: Outer projection with concat on dim1.
SELECT dim1 || '!' AS tag, m1
FROM (SELECT dim1, m1 FROM foo2 UNION ALL SELECT dim1, m1 FROM foo);
+---------+-----+
| tag     | m1  |
+---------+-----+
| !       | 1.0 |
| 1!      | 4.0 |
| 10.1!   | 2.0 |
| 2!      | 3.0 |
| abc!    | 6.0 |
| def!    | 5.0 |
| druid!  | 1.0 |
| друид!  | 1.0 |
| דרואיד! | 1.0 |
+---------+-----+
(9 rows)

!ok
