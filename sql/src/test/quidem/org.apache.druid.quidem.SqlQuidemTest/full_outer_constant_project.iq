!use druidtest://?componentSupplier=StandardComponentSupplier&datasets=sql/src/test/quidem/druidjoinrule-fullouter-dataset
!set outputformat mysql

# Ensures that FULL OUTER JOIN constant projects are handled properly by the hoisting
# logic in DruidJoinRule.
#
# Table left_dims.a: 'abc', 'xyz'
# Table right_nulls.k: 'abc', NULL

SELECT l.a, r.tag
FROM left_dims l
FULL JOIN (SELECT k, 42 AS tag FROM right_nulls) r ON l.a = r.k
ORDER BY 1, 2;
+-----+-----+
| a   | tag |
+-----+-----+
|     |  42 |
| abc |  42 |
| xyz |     |
+-----+-----+
(3 rows)

